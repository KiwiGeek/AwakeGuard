<ui:FluentWindow x:Class="AwakeGuard.Dialogs.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Width="400"
        MinHeight="0"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar x:Name="DialogTitleBar"
                     Grid.Row="0"
                     ShowMaximize="False"
                     ShowMinimize="False"
                     ShowClose="True"
                     ForceShutdown="False"
                     CloseClicked="TitleBar_CloseClicked" />

        <StackPanel Grid.Row="1" Margin="24,12,24,20">
            <TextBlock x:Name="MessageText"
                       TextWrapping="Wrap"
                       Opacity="0.9"
                       Margin="0,0,0,20" />

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <ui:Button x:Name="SecondaryButton"
                           Appearance="Secondary"
                           Padding="16,8"
                           Margin="0,0,8,0"
                           Click="SecondaryButton_Click"
                           IsDefault="False" />
                <ui:Button x:Name="PrimaryButton"
                           Appearance="Primary"
                           Padding="16,8"
                           Click="PrimaryButton_Click" />
            </StackPanel>
        </StackPanel>
    </Grid>
</ui:FluentWindow>

<ui:FluentWindow x:Class="AwakeGuard.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:conv="clr-namespace:AwakeGuard.Converters"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="AwakeGuard"
                 Width="440"
                 Height="620"
                 MinWidth="400"
                 MinHeight="620"
                 ExtendsContentIntoTitleBar="True"
                 KeyDown="MainWindow_KeyDown"
                 SizeToContent="Manual"
                 WindowBackdropType="Mica"
                 WindowStartupLocation="CenterScreen">
    <ui:FluentWindow.Resources>
        <conv:InverseBooleanConverter x:Key="InverseBoolConverter" />
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Title="AwakeGuard"
                     Grid.Row="0"
                     CloseClicked="TitleBar_CloseClicked"
                     ForceShutdown="False"
                     ShowMaximize="False"
                     ShowMinimize="True" />

        <Grid Grid.Row="1"
              Margin="20,12,20,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Margin="0,0,0,14"
                       Opacity="0.75"
                       Text="Keep your PC awake and prevent automatic lock or sleep."
                       TextWrapping="Wrap" />

            <ui:Card Grid.Row="1"
                     Margin="0,0,0,12"
                     VerticalContentAlignment="Top">
                <StackPanel>
                    <TextBlock Margin="0,0,0,10"
                               FontWeight="SemiBold"
                               Text="Protection" />
                    <CheckBox Margin="0,0,0,6"
                              Content="Prevent PC from sleeping"
                              IsChecked="{Binding PreventSleep, Mode=TwoWay}" />
                    <CheckBox Content="Prevent screensaver and display lock"
                              IsChecked="{Binding PreventDisplayOff, Mode=TwoWay}" />
                </StackPanel>
            </ui:Card>

            <ui:Card Grid.Row="2"
                     Margin="0,0,0,12"
                     VerticalContentAlignment="Top">
                <StackPanel>
                    <TextBlock Margin="0,0,0,10"
                               FontWeight="SemiBold"
                               Text="Startup" />
                    <CheckBox Content="Start with Windows"
                              IsChecked="{Binding StartWithWindows, Mode=TwoWay}" />
                </StackPanel>
            </ui:Card>

            <ui:Card Grid.Row="3"
                     VerticalContentAlignment="Top">
                <StackPanel>
                    <TextBlock Margin="0,0,0,10"
                               FontWeight="SemiBold"
                               Text="Duration" />
                    <ComboBox Margin="0,0,0,10"
                              HorizontalAlignment="Stretch"
                              DisplayMemberPath="Label"
                              IsEnabled="{Binding IsActive, Converter={StaticResource InverseBoolConverter}, FallbackValue=True}"
                              ItemsSource="{Binding Durations}"
                              SelectedItem="{Binding SelectedDuration}" />
                    <TextBlock MinHeight="36"
                               Opacity="0.85"
                               Text="{Binding StatusText}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </ui:Card>

            <Grid Grid.Row="5"
                  Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <WrapPanel Grid.Column="0"
                           Orientation="Horizontal">
                    <ui:Button Margin="0,0,8,8"
                               Padding="14,8"
                               Appearance="Secondary"
                               Click="About_Click"
                               Content="About" />
                </WrapPanel>

                <StackPanel Grid.Column="1"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Orientation="Horizontal">
                    <ui:Button Margin="0,0,8,0"
                               Padding="14,8"
                               Appearance="Secondary"
                               Command="{Binding TurnOffCommand}"
                               Content="Turn off" />
                    <ui:Button Padding="14,8"
                               Appearance="Primary"
                               Command="{Binding TurnOnCommand}"
                               Content="Turn on" />
                </StackPanel>
            </Grid>

            <ContentPresenter x:Name="RootDialogPresenter"
                              Grid.Row="0"
                              Grid.RowSpan="6" />
        </Grid>
    </Grid>
</ui:FluentWindow>

#include "resource.h"
#include "version.h"

#include <windows.h>
#include <winver.h>
#include <commctrl.h>

LANGUAGE LANG_NEUTRAL, SUBLANG_NEUTRAL

/////////////////////////////////////////////////////////////////////////////
// Application and tray icons (paths generated in build/generated/icons.rc)
/////////////////////////////////////////////////////////////////////////////
#include "icons.rc"

/////////////////////////////////////////////////////////////////////////////
// Version info -- shows up under Explorer -> Properties -> Details and is
// the canonical place Windows reads LegalCopyright from. Keep the four-part
// Version numbers come from version.h / MSBuild (see Directory.Build.props).
/////////////////////////////////////////////////////////////////////////////
VS_VERSION_INFO VERSIONINFO
 FILEVERSION    AWAKEGUARD_VERSION_MAJOR,AWAKEGUARD_VERSION_MINOR,AWAKEGUARD_VERSION_PATCH,AWAKEGUARD_VERSION_REVISION
 PRODUCTVERSION AWAKEGUARD_VERSION_MAJOR,AWAKEGUARD_VERSION_MINOR,AWAKEGUARD_VERSION_PATCH,AWAKEGUARD_VERSION_REVISION
 FILEFLAGSMASK  VS_FFI_FILEFLAGSMASK
#ifdef _DEBUG
 FILEFLAGS      VS_FF_DEBUG
#else
 FILEFLAGS      0
#endif
 FILEOS         VOS_NT_WINDOWS32
 FILETYPE       VFT_APP
 FILESUBTYPE    VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904B0"
        BEGIN
            VALUE "CompanyName",      "Joshua Penman"
            VALUE "FileDescription",  "AwakeGuard XP LOL - museum edition for Windows XP"
            VALUE "FileVersion",      AWAKEGUARD_FILE_VERSION_STR
            VALUE "InternalName",     "AwakeGuard-XP-LOL"
            VALUE "LegalCopyright",   "Copyright (C) 2026 Joshua Penman. Licensed under GPL-3.0-or-later."
            VALUE "OriginalFilename", "AwakeGuard-XP-LOL.exe"
            VALUE "ProductName",      "AwakeGuard XP LOL"
            VALUE "ProductVersion",   AWAKEGUARD_PRODUCT_VERSION_STR
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END

IDD_CONFIRM DIALOGEX 0, 0, 400, 190
STYLE DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Confirm"
FONT 10, "Tahoma"
BEGIN
    LTEXT "", IDC_CONFIRM_MESSAGE, 20, 20, 360, 96
    PUSHBUTTON "", IDC_CONFIRM_SECONDARY, 180, 140, 96, 30
    DEFPUSHBUTTON "", IDC_CONFIRM_PRIMARY, 284, 140, 96, 30
END

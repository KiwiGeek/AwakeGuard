## Combined .gitignore for AwakeGuard (WPF + Win32 in one repo).
## Based on https://github.com/github/gitignore/blob/main/VisualStudio.gitignore
## plus CMake/MSVC native build output.

# ---------------------------------------------------------------------------
# User-specific files
# ---------------------------------------------------------------------------
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs
mono_crash.*

# ---------------------------------------------------------------------------
# Build results (shared across WPF and Win32)
# ---------------------------------------------------------------------------
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Oo]ut/
[Ll]og/
[Ll]ogs/

# CMake / Ninja / MSVC native build trees
[Bb]uild/
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
CTestTestfile.cmake
compile_commands.json
*.cmake.in
!CMakeLists.txt

# Visual Studio cache/options directory
.vs/

# Visual Studio 2017+ auto generated files
Generated\ Files/

# Test results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.VisualState.xml
TestResult.xml
nunit-*.xml

# ATL output
[Dd]ebugPS/
[Rr]eleasePS/
dlldata.c

# ---------------------------------------------------------------------------
# Compiler-generated intermediates
# ---------------------------------------------------------------------------
*_i.c
*_p.c
*_h.h
*.ilk
*.meta
*.obj
*.iobj
*.pch
*.pdb
*.ipdb
*.pgc
*.pgd
*.rsp
*.sbr
*.tlb
*.tli
*.tlh
*.tmp
*.tmp_proj
*_wpftmp.csproj
*.log
*.vspscc
*.vssscc
.builds
*.pidb
*.svclog
*.scc

# Visual C++ cache
ipch/
*.aps
*.ncb
*.opendb
*.opensdf
*.sdf
*.cachefile
*.VC.db
*.VC.VC.opendb

# Visual Studio profiler / trace
*.psess
*.vsp
*.vspx
*.sap
*.e2e

# MSBuild binary / structured log
*.binlog

# ---------------------------------------------------------------------------
# .NET / NuGet
# ---------------------------------------------------------------------------
project.lock.json
project.fragment.lock.json
artifacts/
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets

# Publish output
publish/
*.[Pp]ublish.xml
*.azurePubxml
*.pubxml
*.publishproj

# ---------------------------------------------------------------------------
# Coverage tooling
# ---------------------------------------------------------------------------
coverage*.json
coverage*.xml
coverage*.info
*.coverage
*.coveragexml
*.dotCover
.axoCover/*
!.axoCover/settings.json

# ---------------------------------------------------------------------------
# Editors / IDEs
# ---------------------------------------------------------------------------
*.[Cc]ache
!?*.[Cc]ache/
~$*
*~
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user
.idea/
.localhistory/
.ionide/

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
*.pfx
*.publishsettings
FodyWeavers.xsd
node_modules/
__pycache__/
*.pyc

# Local scratch / emulator trees (not part of the repo)
/pcjs/
/_cpptest*.exe
/_crttest*.exe
/_err*.txt
/_libgcc_members.txt
